# ─────────────────────────────────────────────────────
# .env.example
# ─────────────────────────────────────────────────────
# SAFE TO COMMIT — contains no real secrets
#
# Purpose:
#   Shows everyone what environment variables this
#   project needs without revealing real values.
#
# How to use:
#   1. Copy this file and rename copy to .env
#   2. Replace placeholder values with your real keys
#   3. Never commit .env — it is blocked by .gitignore
#
# Get a free Groq API key at:
#   https://console.groq.com/keys
# ─────────────────────────────────────────────────────

GROQ_API_KEY=your_groq_api_key_here
MODEL=llama3-8b-8192